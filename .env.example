# =============================================================================
# DGX Spark AI Stack — Environment Configuration
# Copy to .env and adjust values before running docker compose up
# =============================================================================

# --- Host paths (bind mounts) ------------------------------------------------
MODELS_DIR=/srv/ai/models
HF_CACHE_DIR=/srv/ai/cache/hf
OUTPUTS_DIR=/srv/ai/outputs
ASSETS_DIR=/srv/ai/assets
LOGS_DIR=/srv/ai/logs

# --- GPU / CUDA ---------------------------------------------------------------
NVIDIA_VISIBLE_DEVICES=all
CUDA_VISIBLE_DEVICES=0

# --- Networking ---------------------------------------------------------------
GATEWAY_PORT=8080
FRONTEND_PORT=3000
REDIS_PORT=6379

# --- Wan 2.1 ------------------------------------------------------------------
# Model variant: "1.3B" or "14B". Default to 1.3B for stability.
WAN21_MODEL_VARIANT=1.3B
WAN21_MAX_CONCURRENT=1
WAN21_IDLE_TIMEOUT=300
WAN21_MAX_VIDEO_LENGTH=10
WAN21_MAX_RESOLUTION=512

# --- Faster-Whisper -----------------------------------------------------------
WHISPER_MODEL_SIZE=medium
WHISPER_COMPUTE_TYPE=float16
WHISPER_BEAM_SIZE=5

# --- F5-TTS ------------------------------------------------------------------
F5TTS_IDLE_TIMEOUT=1800
F5TTS_SAMPLE_RATE=24000

# --- Optional TTS Providers --------------------------------------------------
FISH_SPEECH_ENABLED=false
FISH_SPEECH_DISPLAY_NAME=Fish Speech
# Point this at a Fish Speech-compatible runtime (official /v1/tts API).
FISH_SPEECH_RUNTIME_URL=
FISH_SPEECH_RUNTIME_HEALTH_PATH=/v1/health
FISH_SPEECH_RUNTIME_TTS_PATH=/v1/tts
FISH_SPEECH_TIMEOUT_SEC=300
FISH_SPEECH_OUTPUT_FORMATS=wav,mp3,opus
FISH_SPEECH_TARGET_SAMPLE_RATES=

PREMIUM_CLONE_TTS_ENABLED=false
PREMIUM_CLONE_TTS_DISPLAY_NAME=Premium Clone TTS
# TODO(runtime): set this when wiring the premium provider to a real backend.
PREMIUM_CLONE_TTS_UPSTREAM_URL=
PREMIUM_CLONE_TTS_HEALTH_PATH=/healthz
PREMIUM_CLONE_TTS_SYNTH_PATH=/synthesize
PREMIUM_CLONE_TTS_TIMEOUT_SEC=300
PREMIUM_CLONE_TTS_OUTPUT_FORMATS=wav
PREMIUM_CLONE_TTS_TARGET_SAMPLE_RATES=
PREMIUM_CLONE_TTS_SUPPORTS_48KHZ_OUTPUT=false

# --- LivePortrait -------------------------------------------------------------
LIVEPORTRAIT_IDLE_TIMEOUT=1800

# --- Lip-sync (video-retalking) -----------------------------------------------
LIPSYNC_IDLE_TIMEOUT=1800
# Backend: "video-retalking" (default), "sadtalker" (experimental)
LIPSYNC_BACKEND=video-retalking

# --- Idle Manager -------------------------------------------------------------
IDLE_CHECK_INTERVAL=60
IDLE_MANAGER_GATEWAY_URL=http://localhost:8080

# --- Memory Safety (UMA) -----------------------------------------------------
# Percentage thresholds
MEMORY_WARN_THRESHOLD=70
MEMORY_HARD_LIMIT=80

# Per-tier memory reservations: minimum GB that must remain available
# before a job of that tier is admitted.
# Heavy (wan21): needs ~40 GB free to safely load + generate
MEM_RESERVE_HEAVY_GB=40
# Medium (tts, liveportrait, lipsync): needs ~10 GB free
MEM_RESERVE_MEDIUM_GB=10
# Light (whisper): needs ~2 GB free
MEM_RESERVE_LIGHT_GB=2

# --- Logging ------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
